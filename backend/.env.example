DATABASE_URL=postgresql+psycopg://username:password@localhost:5443/agentify
DOCKER_DATABASE_URL=postgresql+psycopg://username:password@host.docker.internal:5443/agentify
INTERNAL_API_KEY=agentify-dev-key
ALLOW_ORIGINS_REGEX=.*
APP_PROXY_ROOT_PATH=
BACKEND_PORT=8766
GMAIL_QUERY=has:attachment newer_than:7d
GMAIL_STATE_FILE=processed.json
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_REDIRECT_URI=http://localhost:8766/api/v1/gmail-connections/oauth/callback
GMAIL_FRONTEND_RETURN_URL=http://localhost:5173/setup
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
